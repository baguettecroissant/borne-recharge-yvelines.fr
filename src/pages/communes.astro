---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';
import communes from '../data/communes.json';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const title = `Installateurs Borne de Recharge par Ville en Yvelines (78) | Liste Complète`;
const description = `Retrouvez toutes les communes des Yvelines (78) couvertes par nos installateurs de borne de recharge qualifiés IRVE. Sélectionnez votre ville pour comparer les devis.`;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes des Yvelines" }
];

// Sort communes alphabetically
const sortedCommunes = [...communes].sort((a, b) => a.nom.localeCompare(b.nom, 'fr'));

// Group communes by their first letter
const groups: Record<string, typeof communes> = {};
sortedCommunes.forEach(commune => {
  const firstLetter = commune.nom.charAt(0).toUpperCase();
  if (!groups[firstLetter]) {
    groups[firstLetter] = [];
  }
  groups[firstLetter].push(commune);
});

const alphabet = Object.keys(groups).sort();
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Hero Banner -->
  <section style="background: linear-gradient(135deg, #022c22 0%, #064e3b 100%); color: white; padding: 60px 0; text-align: center; position: relative;">
    <div class="container" style="max-width: 900px; margin: 0 auto; position: relative; z-index: 2;">
      <h1 style="color: white; font-family: var(--font-heading); font-size: 38px; margin-bottom: 15px;">
        📍 Répertoire des Communes des Yvelines (78)
      </h1>
      <p style="color: var(--primary-light); font-size: 16px; max-width: 700px; margin: 0 auto; line-height: 1.6;">
        Trouvez un électricien agréé IRVE près de chez vous. Sélectionnez votre commune pour accéder aux aides de l'État, aux guides d'installation et comparer les devis.
      </p>
    </div>
  </section>

  <!-- Navigation par lettre -->
  <section style="background-color: var(--card-bg); padding: 25px 0; border-bottom: 1px solid var(--border-color);">
    <div class="container" style="display: flex; justify-content: center; flex-wrap: wrap; gap: 8px;">
      {alphabet.map(letter => (
        <a href={`#letter-${letter}`} style="background: var(--bg); border: 1px solid var(--border-color); color: var(--primary); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; font-weight: 700; border-radius: 4px; transition: var(--transition);">
          {letter}
        </a>
      ))}
    </div>
  </section>

  <!-- Contenu Principal -->
  <section style="padding: 60px 0; background-color: var(--bg);">
    <div class="container" style="max-width: 1000px; margin: 0 auto;">
      <div style="background: var(--card-bg); padding: 40px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
        <h2 style="font-family: var(--font-heading); font-size: 28px; color: var(--primary); margin-bottom: 30px; border-bottom: 2px solid var(--primary-light); padding-bottom: 10px; text-align: center;">
          Trouvez un artisan local qualifié IRVE
        </h2>

        <div style="display: flex; flex-direction: column; gap: 40px;">
          {alphabet.map(letter => (
            <div id={`letter-${letter}`} style="scroll-margin-top: 100px;">
              <h3 style="font-family: var(--font-heading); font-size: 24px; color: var(--accent-hover); border-bottom: 2px solid var(--border-color); padding-bottom: 6px; margin-bottom: 20px;">
                {letter}
              </h3>
              <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
                {groups[letter].map(commune => (
                  <div style="background: var(--bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px; display: flex; flex-direction: column; gap: 12px; transition: var(--transition); box-shadow: var(--shadow-sm);">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                      <span style="font-weight: 700; font-size: 16px; color: var(--primary);">{commune.nom}</span>
                      <span style="font-size: 11px; background: var(--primary-light); color: var(--primary); padding: 2px 6px; border-radius: 4px; font-weight: bold; border: 1px solid var(--border-color);">{commune.codePostal}</span>
                    </div>
                    
                    <div style="display: flex; flex-direction: column; gap: 6px; font-size: 13.5px; border-top: 1px solid var(--border-color); padding-top: 10px;">
                      <a href={`/installateur-borne-recharge-${commune.slug}/`} style="display: flex; align-items: center; justify-content: space-between; color: var(--text); font-weight: 600;">
                        <span>🔌 Installateur IRVE</span>
                        <span style="color: var(--accent-hover);">&rarr;</span>
                      </a>
                      <a href={`/borne-recharge-copropriete-${commune.slug}/`} style="display: flex; align-items: center; justify-content: space-between; color: var(--text);">
                        <span>🏢 En Copropriété</span>
                        <span style="color: var(--accent-hover);">&rarr;</span>
                      </a>
                      <a href={`/wallbox-${commune.slug}/`} style="display: flex; align-items: center; justify-content: space-between; color: var(--text);">
                        <span>⚡ Modèles Wallbox</span>
                        <span style="color: var(--accent-hover);">&rarr;</span>
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  a[href^="#letter-"]:hover {
    background: var(--primary) !important;
    color: white !important;
    border-color: var(--primary) !important;
    transform: translateY(-2px);
  }
  div[style*="box-shadow"]:hover {
    transform: translateY(-2px);
    border-color: var(--accent) !important;
    box-shadow: var(--shadow-md) !important;
  }
</style>
