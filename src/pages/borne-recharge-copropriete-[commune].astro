---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import CityMap from '../components/CityMap.astro';
import StepsForm from '../components/StepsForm.astro';
import config from '../data/config.json';
import communes from '../data/communes.json';
import { generateCommuneContent, getDynamicPrices } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';

export async function getStaticPaths() {
  return communes.map((c) => ({
    params: { commune: c.slug },
    props: { commune: c },
  }));
}

const { commune } = Astro.props;
const content = generateCommuneContent(commune, 'copropriete');
const prices = getDynamicPrices(commune);

const title = `Borne de Recharge Copropriété ${commune.nom} (${commune.codePostal}) | Devis & Droit à la Prise`;
const description = `Vous résidez en appartement à ${commune.nom} ? Installez votre borne de recharge en copropriété. Obtenez 3 devis gratuits, droit à la prise et subventions ADVENIR.`;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes (78)", href: "/communes/" },
  { label: `Copropriété ${commune.nom}` }
];

// Get nearby communes for interlinking
const nearby = getSmartNearbyCommunes(commune.slug, communes, 6, 2);
---

<Layout title={title} description={description}>
  <SchemaMarkup 
    slot="head" 
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    breadcrumbItems={breadcrumbItems}
    communeName={commune.nom}
    faqItems={content.faqItems}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Localized Hero Section -->
  <section class="hero" style="background: linear-gradient(135deg, rgba(20, 83, 45, 0.95) 0%, rgba(5, 46, 22, 0.9) 100%), url('/images/hero-borne-recharge-yvelines.png') no-repeat center center; background-size: cover; color: white; padding: 60px 0 70px; position: relative;">
    <div class="container">
      <div class="hero-inner" style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 40px; align-items: center;">
        <div>
          <span class="hero-badge" style="background-color: var(--accent); color: white;">🏢 Solutions de Recharge en Résidence - {commune.nom}</span>
          <h1 style="font-size: 34px; color: white; line-height: 1.25; margin-bottom: 20px; font-weight: 600; font-family: var(--font-heading);">
            Recharge en Copropriété à {commune.nom} ({commune.codePostal})
          </h1>
          <p style="font-size: 16px; color: var(--primary-light); margin-bottom: 25px; line-height: 1.6;">
            {content.introParagraph}
          </p>
          <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-top: 20px;">
            <div style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); padding: 12px 18px; border-radius: 8px; font-size: 13.5px;">
              <strong>Reste à charge estimé :</strong><br/>
              À partir de <span style="color: var(--secondary); font-weight: bold; font-size: 15px;">{prices.wallbox7kW.min - 960 - 500} € TTC</span>
            </div>
            <div style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); padding: 12px 18px; border-radius: 8px; font-size: 13.5px;">
              <strong>Subventions cumulées :</strong><br/>
              Jusqu'à <span style="color: var(--secondary); font-weight: bold; font-size: 15px;">{content.savingsEstimate}</span>
            </div>
          </div>
        </div>
        
        <!-- Interactive Multi-Step Form -->
        <div id="devis">
          <StepsForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Local Page Content & Structure -->
  <section class="static-page-section" style="padding: 65px 0; background-color: var(--bg);">
    <div class="container">
      <div class="two-column-layout">
        
        <!-- Main local content -->
        <div class="static-main-content rich-text" style="background: var(--card-bg); padding: 40px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
          
          <h2>1. Le Droit à la Prise en copropriété à {commune.nom}</h2>
          <p>
            {content.useCaseText}
          </p>
          <p>
            {content.localContext}
          </p>

          <blockquote style="border-left: 4px solid var(--accent); background: var(--primary-light); padding: 15px 20px; margin: 25px 0; border-radius: var(--radius-sm); color: var(--primary);">
            <strong>⚡ Réglementation en vigueur :</strong> {content.localRegulation}
          </blockquote>

          <!-- Unique: Step-by-step Droit à la Prise timeline -->
          <h2>2. Les 5 étapes clés pour installer votre borne en copropriété à {commune.nom}</h2>
          <div style="display: flex; flex-direction: column; gap: 16px; margin: 20px 0;">
            <div style="display: flex; gap: 16px; align-items: flex-start;">
              <div style="min-width: 40px; height: 40px; background: var(--secondary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 16px; flex-shrink: 0;">1</div>
              <div>
                <strong style="color: var(--primary);">Réaliser l'étude technique préalable</strong>
                <p style="margin: 4px 0 0; font-size: 13.5px; color: var(--text-muted);">Un électricien IRVE inspecte le parking, le TGBT et les chemins de câbles de votre résidence à {commune.nom}. Il établit un plan d'implantation et un devis détaillé.</p>
              </div>
            </div>
            <div style="display: flex; gap: 16px; align-items: flex-start;">
              <div style="min-width: 40px; height: 40px; background: var(--secondary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 16px; flex-shrink: 0;">2</div>
              <div>
                <strong style="color: var(--primary);">Notifier le syndic par lettre recommandée</strong>
                <p style="margin: 4px 0 0; font-size: 13.5px; color: var(--text-muted);">Envoyez votre demande de droit à la prise accompagnée du devis technique au syndic de votre copropriété à {commune.nom}. Le syndic a 3 mois pour réagir.</p>
              </div>
            </div>
            <div style="display: flex; gap: 16px; align-items: flex-start;">
              <div style="min-width: 40px; height: 40px; background: var(--secondary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 16px; flex-shrink: 0;">3</div>
              <div>
                <strong style="color: var(--primary);">Présentation en Assemblée Générale</strong>
                <p style="margin: 4px 0 0; font-size: 13.5px; color: var(--text-muted);">Le projet est inscrit à l'ordre du jour de la prochaine AG. Les copropriétaires de {commune.nom} votent le principe d'installation. En cas de silence du syndic, vous pouvez procéder.</p>
              </div>
            </div>
            <div style="display: flex; gap: 16px; align-items: flex-start;">
              <div style="min-width: 40px; height: 40px; background: var(--secondary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 16px; flex-shrink: 0;">4</div>
              <div>
                <strong style="color: var(--primary);">Travaux d'installation par un artisan IRVE</strong>
                <p style="margin: 4px 0 0; font-size: 13.5px; color: var(--text-muted);">L'électricien certifié réalise le raccordement, pose le sous-compteur MID et installe la borne sur votre emplacement de parking à {commune.nom}.</p>
              </div>
            </div>
            <div style="display: flex; gap: 16px; align-items: flex-start;">
              <div style="min-width: 40px; height: 40px; background: var(--secondary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 16px; flex-shrink: 0;">5</div>
              <div>
                <strong style="color: var(--primary);">Mise en service et dossier ADVENIR</strong>
                <p style="margin: 4px 0 0; font-size: 13.5px; color: var(--text-muted);">Votre borne est mise en service et l'attestation IRVE est délivrée. Le dossier de subvention ADVENIR (jusqu'à 960 €) est constitué pour obtenir votre remboursement.</p>
              </div>
            </div>
          </div>

          <h2>3. Contexte local et mobilité à {commune.nom}</h2>
          <p>
            {content.mobiliteContext}
          </p>
          <p>
            {content.populationTierContent}
          </p>

          <h2>4. Intégration architecturale et patrimoine local à {commune.nom}</h2>
          <p>
            {content.anecdotePatrimoine}
          </p>
          <h2>5. Prix et subventions de recharge en copropriété à {commune.nom} (2026)</h2>
          <p>
            {content.tableIntro}
          </p>

          <div class="table-scroll-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Type de Raccordement</th>
                  <th>Puissance</th>
                  <th>Coût Moyen Posé</th>
                  <th>Aides Cumulées Déduites*</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Solution Individuelle (Compteur Parties Communes)</strong></td>
                  <td>7.4 kW (32A)</td>
                  <td class="price">{prices.wallbox7kW.min} € - {prices.wallbox7kW.max} €</td>
                  <td style="font-weight: bold; color: var(--secondary);">{prices.wallbox7kW.min - 960 - 500} € - {prices.wallbox7kW.max - 960 - 500} €</td>
                </tr>
                <tr>
                  <td><strong>Infrastructure Collective (Colonne Horizontale Enedis)</strong></td>
                  <td>7.4 à 22 kW</td>
                  <td class="price">{prices.copro.min} € - {prices.copro.max} €</td>
                  <td style="font-weight: bold; color: var(--secondary);">{prices.copro.min - 960} € - {prices.copro.max - 960} €</td>
                </tr>
                <tr>
                  <td><strong>Solution Triphasée Spécifique (Compteur Dédié)</strong></td>
                  <td>11 / 22 kW</td>
                  <td class="price">{prices.wallbox22kW.min} € - {prices.wallbox22kW.max} €</td>
                  <td style="font-weight: bold; color: var(--secondary);">{prices.wallbox22kW.min - 960 - 500} € - {prices.wallbox22kW.max - 960 - 500} €</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p style="font-size: 12.5px; color: var(--text-muted); line-height: 1.45; margin-top: 10px;">
            * Les aides calculées pour les copropriétaires de {commune.nom} incluent la prime ADVENIR individuelle (couvrant 50% du montant HT du projet, dans la limite de 960 € TTC) combinée au crédit d'impôt forfaitaire de 500 € pour l'installation d'une borne connectée.
          </p>

          <h2>6. Diagnostics techniques &amp; spécificités de raccordement dans le 78</h2>
          <p>
            {content.communeDataInsight}
          </p>
          <p>
            {content.specificiteElectrique}
          </p>
          <p>
            {content.logisticsAlert}
          </p>

          <!-- Localized Illustration Image -->
          <div style="margin: 30px 0; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
            <!-- guide-copro.png in Yvelines -->
            <img src="/images/guide-copro.png" alt={`Installation collective borne de recharge en copropriété à ${commune.nom}`} style="width: 100%; height: auto; max-height: 350px; object-fit: cover; display: block;" />
          </div>

          <!-- Interactive Map component -->
          <div style="margin: 30px 0; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
            <CityMap cityName={commune.nom} zip={commune.codePostal} />
          </div>

          <h2>7. Plus-value immobilière de la recharge en résidence collective</h2>
          <p>
            {content.marcheImmobilierInsight}
          </p>
          <p>
            {content.realEstateInsight}
          </p>

          <h2>8. Économies en copropriété : amortissement et charges</h2>
          <p>
            {content.ecoText}
          </p>

          <!-- External Resources & Official Links -->
          <div style="margin-top: 40px; border-top: 1px solid var(--border-color); padding-top: 30px;">
            <h2>9. Liens institutionnels &amp; ressources de référence</h2>
            <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 15px;">Accédez aux informations réglementaires et aides pour votre projet de borne de recharge en copropriété à {commune.nom} :</p>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              {content.externalLinks.map((link) => (
                <a href={link.url} target="_blank" rel="noopener noreferrer" style="display: flex; gap: 12px; padding: 14px 18px; background: var(--bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); transition: var(--transition); align-items: flex-start;">
                  <span style="font-size: 18px; flex-shrink: 0;">🔗</span>
                  <div>
                    <span style="font-weight: 700; font-size: 14px; color: var(--secondary); display: block;">{link.label}</span>
                    <span style="font-size: 12.5px; color: var(--text-muted); line-height: 1.4; display: block; margin-top: 3px;">{link.description}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Guide Links -->
          <div style="margin-top: 35px; background: var(--primary-light); border: 1.5px solid var(--border-color); padding: 25px; border-radius: var(--radius-md);">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16px; font-weight: 600; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">📖 Guides et dossiers thématiques</h3>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              {content.guideLinks.map((guide) => (
                <a href={guide.href} style="display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); transition: var(--transition);">
                  <div>
                    <span style="font-weight: 700; font-size: 13.5px; color: var(--secondary);">{guide.label}</span>
                    <span style="font-size: 12px; color: var(--text-muted); display: block; margin-top: 2px;">{guide.desc}</span>
                  </div>
                  <span style="color: var(--accent); font-size: 16px; flex-shrink: 0;">→</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Sources Citation -->
          <p style="font-size: 11.5px; color: var(--text-muted); margin-top: 25px; font-style: italic; border-top: 1px solid var(--border-color); padding-top: 15px;">
            {content.sourcesCitation} — Mis à jour : {content.lastUpdated}
          </p>

          <!-- FAQ Accordion specific to the town -->
          <h2 style="margin-top: 40px;">FAQ : Questions fréquentes en Copropriété à {commune.nom}</h2>
          <div style="display: flex; flex-direction: column; gap: 14px; margin-top: 20px;">
            {content.faqItems.map((faq) => (
              <details class="faq-details">
                <summary>{faq.question}</summary>
                <div class="faq-answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>

          <!-- Interlinking to nearby communes -->
          <div style="border-top: 1px solid var(--border-color); padding-top: 35px; margin-top: 45px;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16px; margin-bottom: 15px;">📍 Installation en copropriété dans les communes voisines :</h3>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
              {nearby.slice(0, 5).map((n) => (
                <a href={`/borne-recharge-copropriete-${n.slug}/`} style="font-size: 13px; color: var(--secondary); font-weight: 600; background: var(--primary-light); padding: 8px 12px; border-radius: 4px; border: 1.5px solid var(--border-color); text-decoration: none;">
                  🏢 Copropriété {n.nom} ({n.codePostal}) &rarr;
                </a>
              ))}
              {nearby.slice(5, 7).map((n) => (
                <a href={`/installateur-borne-recharge-${n.slug}/`} style="font-size: 13px; color: var(--secondary); font-weight: 600; background: var(--primary-light); padding: 8px 12px; border-radius: 4px; border: 1.5px solid var(--border-color); text-decoration: none;">
                  🔌 Installateur {n.nom} ({n.codePostal}) &rarr;
                </a>
              ))}
              {nearby.slice(7, 8).map((n) => (
                <a href={`/wallbox-${n.slug}/`} style="font-size: 13px; color: var(--secondary); font-weight: 600; background: var(--primary-light); padding: 8px 12px; border-radius: 4px; border: 1.5px solid var(--border-color); text-decoration: none;">
                  ⚡ Wallbox {n.nom} ({n.codePostal}) &rarr;
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="static-sidebar">
          <div class="sidebar-widget bg-purple-gradient" style="background: linear-gradient(135deg, var(--primary) 0%, #052e16 100%); color: white; border: 1px solid var(--border-color);">
            <h3 style="color: white; margin-top: 0;">🧮 Devis Copropriété {commune.nom}</h3>
            <p style="color: var(--primary-light); font-size: 13px; margin-bottom: 20px;">Notre bureau d'études partenaire élabore un devis gratuit conforme pour votre syndic de copropriété ou bailleur à {commune.nom}.</p>
            <a href="#devis" style="display: block; background: var(--accent); color: white; text-align: center; padding: 12px; border-radius: 50px; font-weight: bold; text-decoration: none; transition: var(--transition);">Demander mes devis &rarr;</a>
          </div>

          <div class="sidebar-widget">
            <h3>🏢 Solutions alternatives</h3>
            <p style="font-size: 13px;">Vous habitez en maison individuelle ou recherchez un comparatif de modèles de bornes ?</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; font-size: 13px;">
              <li>⚡ <a href={`/installateur-borne-recharge-${commune.slug}/`} style="color: var(--secondary); font-weight: 600; text-decoration: none;">Installateur Borne {commune.nom} &rarr;</a></li>
              <li>🔌 <a href={`/wallbox-${commune.slug}/`} style="color: var(--secondary); font-weight: 600; text-decoration: none;">Modèles Wallbox à {commune.nom} &rarr;</a></li>
            </ul>
          </div>

          <div class="sidebar-widget">
            <h3>💡 Conseil d'expert local</h3>
            <p style="font-size: 13px; color: var(--text-muted); line-height: 1.4;">{content.expertTip}</p>
          </div>

          <div class="sidebar-widget">
            <h3>📖 Guides utiles</h3>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px; font-size: 13px; margin-top: 10px;">
              <li>🏢 <a href="/guides/copropriete-versailles-irve-collective-syndic/" style="color: var(--secondary); font-weight: 600; text-decoration: none;">Guide Copropriété Versailles →</a></li>
              <li>💰 <a href="/aides-advenir/" style="color: var(--secondary); font-weight: 600; text-decoration: none;">Aides ADVENIR & Subventions →</a></li>
              <li>🧮 <a href="/tarifs/" style="color: var(--secondary); font-weight: 600; text-decoration: none;">Tarifs Installation 2026 →</a></li>
              <li>🛠️ <a href="/guide-installation/" style="color: var(--secondary); font-weight: 600; text-decoration: none;">Guide Technique Complet →</a></li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>
</Layout>

<style>
  @media (max-width: 992px) {
    .hero-inner {
      grid-template-columns: 1fr !important;
    }
  }
</style>
